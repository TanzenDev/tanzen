{
  "uid": "tanzen-cost-latency",
  "title": "Tanzen — Cost & Latency",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "60s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Datasource"
      },
      {
        "name": "model",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "$datasource" },
        "query": "label_values(tanzen_llm_tokens_total, model)",
        "label": "Model",
        "includeAll": true,
        "multi": true
      },
      {
        "name": "agent_id",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "$datasource" },
        "query": "label_values(tanzen_llm_tokens_total, agent_id)",
        "label": "Agent",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Per-Workflow Token Cost (USD / hr)",
      "description": "Estimated USD cost of LLM calls rolled up per hour",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "sum by (agent_id) (rate(tanzen_llm_cost_usd_sum{model=~\"$model\", agent_id=~\"$agent_id\"}[1h]) * 3600)",
          "legendFormat": "{{ agent_id }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Step Latency p95 (seconds)",
      "description": "95th-percentile activity duration across all workers",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, activity_name) (rate(tanzen_activity_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{ activity_name }}"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le, activity_name) (rate(tanzen_activity_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{ activity_name }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Token Consumption by Model (tokens/min)",
      "description": "Rate of LLM token consumption broken down by model",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "sum by (model) (rate(tanzen_llm_tokens_total{model=~\"$model\"}[5m])) * 60",
          "legendFormat": "{{ model }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Model Cost Breakdown (USD / hr)",
      "description": "Hourly cost per model to identify expensive models",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "sum by (model) (rate(tanzen_llm_cost_usd_sum{model=~\"$model\"}[1h]) * 3600)",
          "legendFormat": "{{ model }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD" }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Agent Cost Breakdown (USD / hr)",
      "description": "Hourly cost per agent to attribute spend",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "sum by (agent_id) (rate(tanzen_llm_cost_usd_sum{agent_id=~\"$agent_id\"}[1h]) * 3600)",
          "legendFormat": "{{ agent_id }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "currencyUSD" }
      }
    }
  ]
}
