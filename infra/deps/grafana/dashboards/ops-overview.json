{
  "uid": "tanzen-ops-overview",
  "title": "Tanzen — Operations Overview",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Datasource"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Run Volume (1 h)",
      "description": "Total workflow runs started in the last hour",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "increase(tanzen_run_started_total[1h])",
          "legendFormat": "Runs"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Success Rate (1 h)",
      "description": "Ratio of succeeded runs to total runs",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "rate(tanzen_run_total{status='succeeded'}[1h]) / clamp_min(rate(tanzen_run_total[1h]), 1)",
          "legendFormat": "Success %"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit" }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active Runs",
      "description": "Runs currently in the running state",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "tanzen_run_total{status='running'}",
          "legendFormat": "Active"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Pending Gates",
      "description": "Human-review gates waiting for approval",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "tanzen_gate_pending_total",
          "legendFormat": "Pending"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Run Volume by Workflow (rate/min)",
      "description": "Per-minute run rate broken down by workflow",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "rate(tanzen_run_started_total[5m]) * 60",
          "legendFormat": "{{ workflow }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqpm", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Activity Failure Rate",
      "description": "Rate of activities completing with status=failure",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "rate(tanzen_activity_total{status='failure'}[5m])",
          "legendFormat": "{{ activity_name }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "color": { "fixedColor": "red", "mode": "fixed" } }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Activity Throughput",
      "description": "Rate of successfully completed activities",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "$datasource" },
      "targets": [
        {
          "expr": "rate(tanzen_activity_total{status='success'}[5m])",
          "legendFormat": "{{ activity_name }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    }
  ]
}
